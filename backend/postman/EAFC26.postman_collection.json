{
  "info": {
    "name": "EAFC26 Player Analytics API",
    "_postman_id": "eafc26-analytics-collection-id",
    "description": "Postman Collection for EAFC 26 Player Analytics and Aggregations Backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Regular User\",\n  \"email\": \"user@test.com\",\n  \"password\": \"Password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Register Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin User\",\n  \"email\": \"admin@test.com\",\n  \"password\": \"AdminPassword123\",\n  \"role\": \"admin\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@test.com\",\n  \"password\": \"Password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Players Management",
      "item": [
        {
          "name": "Get All Players",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/players?limit=10&page=1&sort=-ovr",
              "host": ["{{baseUrl}}"],
              "path": ["players"],
              "query": [
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "sort",
                  "value": "-ovr"
                }
              ]
            }
          }
        },
        {
          "name": "Search Players",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/search/players?q=salah&limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["search", "players"],
              "query": [
                {
                  "key": "q",
                  "value": "salah"
                },
                {
                  "key": "limit",
                  "value": "5"
                }
              ]
            }
          }
        },
        {
          "name": "Get Predefined Filter (Youngsters)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/players/filter/youngsters?limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["players", "filter", "youngsters"],
              "query": [
                {
                  "key": "limit",
                  "value": "5"
                }
              ]
            }
          }
        },
        {
          "name": "Create Player (Admin Required)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Talent\",\n  \"rank\": 1000,\n  \"ovr\": 82,\n  \"age\": 19,\n  \"preferredFoot\": \"Right\",\n  \"position\": \"CAM\",\n  \"team\": \"Real Madrid\",\n  \"league\": \"LaLiga\",\n  \"nation\": \"Spain\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/players",
              "host": ["{{baseUrl}}"],
              "path": ["players"]
            }
          }
        }
      ]
    },
    {
      "name": "Analytics & Statistics",
      "item": [
        {
          "name": "Get Top Rated (Admin Required)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/analytics/players/top-rated?limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["analytics", "players", "top-rated"],
              "query": [
                {
                  "key": "limit",
                  "value": "5"
                }
              ]
            }
          }
        },
        {
          "name": "Get Top Teams (Admin Required)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/analytics/players/top-teams?limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["analytics", "players", "top-teams"],
              "query": [
                {
                  "key": "limit",
                  "value": "5"
                }
              ]
            }
          }
        },
        {
          "name": "Get Position Distribution (Admin Required)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/analytics/players/position-distribution",
              "host": ["{{baseUrl}}"],
              "path": ["analytics", "players", "position-distribution"]
            }
          }
        },
        {
          "name": "Get Database Players Count",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/stats/players/count",
              "host": ["{{baseUrl}}"],
              "path": ["stats", "players", "count"]
            }
          }
        },
        {
          "name": "Get Average Overall Rating",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/stats/players/average-rating",
              "host": ["{{baseUrl}}"],
              "path": ["stats", "players", "average-rating"]
            }
          }
        }
      ]
    },
    {
      "name": "Admin Dashboard",
      "item": [
        {
          "name": "Get Dashboard summary (Admin Required)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/dashboard",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "dashboard"]
            }
          }
        }
      ]
    }
  ]
}
